# Copy to .env and fill in real values. Never commit .env.
# Secrets in CI go in GitHub → Settings → Secrets and variables → Actions.

# Anthropic API (used by pipeline agents)
ANTHROPIC_API_KEY=sk-ant-...

# GitHub token (for opening PRs from the pipeline)
GITHUB_TOKEN=ghp_...

# Target repo for codegen demo
TARGET_REPO_OWNER=MohammedAlsabih
TARGET_REPO_NAME=paperclip-demo-target
